{
	"name": "norman-wong-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"sass": "sass --no-source-map src/lib/styles/app.scss src/app.css",
		"sass:watch": "sass --watch --no-source-map src/lib/styles/app.scss src/app.css"
	},
	"devDependencies": {
		"@portabletext/svelte": "^3.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/lodash": "^4.17.24",
		"sass": "^1.99.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-preprocess": "^6.0.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@sanity/client": "^7.21.0",
		"@sanity/image-url": "^2.1.1",
		"lodash": "^4.18.1"
	}
}